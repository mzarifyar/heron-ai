# Heron environment configuration
# Copy this file to .env and fill in your values.

# ── Core ──────────────────────────────────────────────────────────────────────
HERON_APP_NAME=heron
HERON_ENV=local
HERON_REGION=us-east-1
HERON_API_HOST=0.0.0.0
HERON_API_PORT=8080
HERON_LOG_LEVEL=INFO
HERON_TELEMETRY_BUFFER_SIZE=512

# Optional bearer token to protect the /sense/signals ingest endpoint
# HERON_INGEST_TOKEN=changeme

# ── Jira ──────────────────────────────────────────────────────────────────────
# Your Jira instance base URL (e.g. https://yourorg.atlassian.net)
JIRA_BASE_URL=https://your-jira-instance.atlassian.net/rest/api/2
JIRA_BEARER_TOKEN=
JIRA_PROJECT_KEY=OPS
# URL opened by /jira-auth browser-assisted token bootstrap
HERON_JIRA_BROWSER_AUTH_URL=https://your-jira-instance.atlassian.net
# When true, Heron adds a "processed" label to ingested Jira tickets
HERON_JIRA_INGEST_UPDATE_LABELS=false

# ── Alert source puller ───────────────────────────────────────────────────────
# Base URL for your alert management API (CloudWatch, Datadog, PagerDuty, etc.)
# HERON_ALERT_SOURCE_HOST=https://your-alert-api.example.com
# Path to alert source targets config
# HERON_DEVOPS_PORTAL_TARGETS_PATH=config/devops_portal_targets.json

# ── Operator token (for alert source auth) ───────────────────────────────────
# Set a static token, or configure SSH refresh below
# OPERATOR_ACCESS_TOKEN=

# Optional SSH-based token refresh (leave blank to disable)
# HERON_OPERATOR_TOKEN_ALLOW_SSH_REFRESH=false
# HERON_OPERATOR_TOKEN_SSH_HOST=
# HERON_OPERATOR_TOKEN_SSH_COMMAND=

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to true to run Heron with synthetic incidents — no real infrastructure needed
# HERON_DEMO_MODE=false

# ── Storage paths ─────────────────────────────────────────────────────────────
HERON_LOCAL_DB_PATH=data/heron_local.db
HERON_JIRA_AUTH_STORE_PATH=data/jira_auth.json

# ── Alarm guard ───────────────────────────────────────────────────────────────
HERON_ALARM_GUARD_ENABLED=false
HERON_ALARM_GUARD_DROP_OK=false
HERON_ALARM_GUARD_SCRIPT=tools/get_alarm_status.py
HERON_ALARM_GUARD_TIMEOUT=45

# ── Telemetry (optional) ──────────────────────────────────────────────────────
TELEMETRY_ENABLED=false
# TELEMETRY_ENDPOINT=https://your-metrics-endpoint.example.com
# TELEMETRY_NAMESPACE=heron

# ── Escalation — Slack ────────────────────────────────────────────────────────
# Incoming Webhook URL from your Slack app (Settings > Incoming Webhooks).
# Once set, flip escalation_channels.slack.live.<env> to true in config/policy.yaml.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# Set to false to send live messages (default: true = dry run, log only)
# SLACK_DRY_RUN=false

# ── Escalation — PagerDuty ───────────────────────────────────────────────────
# 32-char integration key from your PagerDuty service (Events API v2 integration).
# Once set, flip escalation_channels.pagerduty.live.<env> to true in config/policy.yaml.
# PAGERDUTY_ROUTING_KEY=your-32-char-integration-key
# Set to false to trigger real pages (default: true = dry run, log only)
# PAGERDUTY_DRY_RUN=false

# ── Reflex live execution ─────────────────────────────────────────────────────
# Target Kubernetes cluster name for live kubectl actions.
# Used by CommandExecutor to resolve kubeconfig via get_kubeconfig_for_cluster().
# Leave unset to use the default KUBECONFIG / ~/.kube/config.
# HERON_KUBE_CLUSTER=my-cluster-name

# ── AI / LLM (Decide step + Intelligence page) ────────────────────────────────
# Provider: anthropic | openai | ollama
# HERON_AI_PROVIDER=anthropic
# HERON_AI_API_KEY=sk-ant-...
# HERON_AI_MODEL=claude-sonnet-4-6        # default for Anthropic
# HERON_AI_BASE_URL=http://localhost:11434 # Ollama only
# HERON_AI_MAX_TOKENS=1024                 # overridden to 4096 for insight generation

# ── Prometheus / Alertmanager ─────────────────────────────────────────────────
# Set PROMETHEUS_ALERTMANAGER_URL and flip prometheus.enabled: true in
# config/pullers.yaml to start pulling firing alerts every 30s.
# PROMETHEUS_ALERTMANAGER_URL=http://alertmanager:9093
# PROMETHEUS_URL=http://prometheus:9090            # optional — enables metric scraping
# PROMETHEUS_AUTH_TOKEN=                           # Bearer token (optional)
# PROMETHEUS_BASIC_USER=                           # Basic auth (alternative to token)
# PROMETHEUS_BASIC_PASS=
# PROMETHEUS_INSECURE_TLS=false                    # set true to skip TLS verification
# PROMETHEUS_TIMEOUT_SECONDS=20
# PROMETHEUS_EXTRA_QUERIES=kafka_lag:kafka_consumer_group_lag:job  # custom PromQL

# ── GitHub deployment correlation ─────────────────────────────────────────────
# Set up a webhook in GitHub repo → Settings → Webhooks → Add webhook
# Payload URL: https://your-heron-host/webhooks/github
# Content type: application/json
# Events: Pushes + Deployments + Deployment statuses
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# GITHUB_DEFAULT_ENV=production

# ── Slack Bot ─────────────────────────────────────────────────────────────────
# Create a Slack App at api.slack.com/apps, then:
#   Slash Commands → /heron → https://your-heron-host/slack/commands
#   Interactivity  → https://your-heron-host/slack/interactive
#   Bot scopes: commands, chat:write, chat:write.public
# SLACK_BOT_TOKEN=xoxb-...        (from OAuth & Permissions after install)
# SLACK_SIGNING_SECRET=...         (from Basic Information)

# ── Microsoft Teams ───────────────────────────────────────────────────────────
# Incoming Webhook: Teams channel → ··· → Connectors → Incoming Webhook → Create
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
# TEAMS_DRY_RUN=false

# ── ArgoCD ────────────────────────────────────────────────────────────────────
# ARGOCD_SERVER_URL=https://argocd.example.com
# ARGOCD_TOKEN=eyJhbGci...          (Settings → Accounts → Generate Token)
# ARGOCD_INSECURE=false             (set true to skip TLS verify)
# ARGOCD_DRY_RUN=false              (flip to false to enable live rollbacks)

# ── Flux CD ───────────────────────────────────────────────────────────────────
# FLUX_WEBHOOK_URL=http://flux-receiver.flux-system.svc/hook/<token>
# FLUX_WEBHOOK_TOKEN=<token>
# FLUX_NAMESPACE=flux-system
# FLUX_DRY_RUN=false
